{
  "name": "Pollix Dev",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:1-20-bullseye",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers-contrib/features/pnpm:2": {
      "version": "8"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "prisma.prisma",
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "formulahendry.auto-rename-tag",
        "christian-kohler.path-intellisense",
        "mikestead.dotenv"
      ],
      "settings": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit"
        },
        "typescript.preferences.importModuleSpecifier": "relative",
        "tailwindCSS.experimental.classRegex": [
          ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"]
        ]
      }
    }
  },
  "forwardPorts": [3000, 3001, 54321, 54322],
  "portsAttributes": {
    "3000": { "label": "Frontend (Next.js)", "onAutoForward": "notify" },
    "3001": { "label": "Backend (NestJS)", "onAutoForward": "notify" },
    "54321": { "label": "Supabase API", "onAutoForward": "silent" },
    "54322": { "label": "Supabase Studio", "onAutoForward": "silent" }
  },
  "postCreateCommand": "pnpm install",
  "postStartCommand": "cp .env.example .env.local 2>/dev/null || true",
  "remoteUser": "node"
}
